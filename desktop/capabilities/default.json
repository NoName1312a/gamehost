{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core window permissions plus permission to spawn the bundled engine sidecar.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "updater:default",
    "process:allow-restart",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "engine", "sidecar": true }]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "engine", "sidecar": true }]
    }
  ]
}
